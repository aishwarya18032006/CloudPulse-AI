# PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/cloudpulse
DATABASE_SSL=false

# API
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_URL=http://localhost:5173

# Gmail SMTP (required for production OTP delivery)
# Use a Google App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="CloudPulse AI <your.email@gmail.com>"

# Google Gemini (AI Assistant — backend only, never expose in frontend)
GEMINI_API_KEY=

# ML Model Server (Python FastAPI)
ML_MODEL_URL=http://localhost:8000
